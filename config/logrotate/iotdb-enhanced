/root/iotdb-enhanced/backend/logs/*.log {
  daily
  rotate 14
  compress
  delaycompress
  missingok
  notifempty
  create 0640 iotdb iotdb
  sharedscripts
  postrotate
    pm2 reload ecosystem.config.cjs >/dev/null 2>&1 || true
  endscript
}

/root/iotdb-enhanced/frontend/.next/logs/*.log {
  daily
  rotate 14
  compress
  delaycompress
  missingok
  notifempty
}
