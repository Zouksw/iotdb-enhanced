# ============================================================================
# IoTDB Enhanced - Production Environment Template
# ============================================================================
# Copy this file to .env.production and update with your production values

# ============================================================================
# Database Configuration
# ============================================================================
# Use your cloud PostgreSQL (AWS RDS, GCP Cloud SQL, Azure Database)
DATABASE_URL="postgresql://username:password@your-db-host:5432/iotdb_enhanced?schema=public&sslmode=require"

# ============================================================================
# Server Configuration
# ============================================================================
PORT=8000
NODE_ENV=production

# ============================================================================
# CORS Configuration
# ============================================================================
# Update with your actual domain
CORS_ORIGIN=https://your-domain.com

# ============================================================================
# JWT Authentication
# ============================================================================
# IMPORTANT: Generate NEW secrets for production!
# Use: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_GENERATE_NEW_SECRET
JWT_EXPIRES_IN=7d

# ============================================================================
# Redis Configuration
# ============================================================================
# Use your cloud Redis (AWS ElastiCache, GCP Memorystore, Azure Cache)
REDIS_URL=redis://your-redis-host:6379

# ============================================================================
# Session Configuration
# ============================================================================
# IMPORTANT: Generate NEW secret for production!
SESSION_SECRET=CHANGE_ME_GENERATE_NEW_SECRET
SESSION_MAX_AGE=604800000

# ============================================================================
# IoTDB Configuration
# ============================================================================
IOTDB_HOST=your-iotdb-server.com
IOTDB_PORT=6679
IOTDB_USERNAME=your_username
IOTDB_PASSWORD=your_secure_password
IOTDB_REST_URL=https://your-iotdb-server.com:18080

# ============================================================================
# Email Configuration (for alerts/notifications)
# ============================================================================
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@your-domain.com

# ============================================================================
# Monitoring & Logging
# ============================================================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
LOG_LEVEL=info

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
