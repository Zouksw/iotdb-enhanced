# IoTDB Enhanced - Log Rotation Configuration
#
# Place in /etc/logrotate.d/iotdb-enhanced
#
# After adding this file, test with:
#   sudo logrotate -d /etc/logrotate.d/iotrotated -v

# Backend application logs
/var/log/iotdb-enhanced/*.log {
    daily
    rotate 14
    compress
    delaycompress
    copytruncate
    missingok
    notifempty
    create 0640 www-data www-data
    dateext
    extension .log
    sharedscripts
    postrotate
    /bin/kill -USR1 $(cat /var/run/iotdb-enhanced.pid 2>/dev/null || echo "No PID file found") >/dev/null 2>&1 || true
    endscript
}

# PM2 logs
/root/.pm2/logs/*.log {
    daily
    rotate 7
    compress
    delaycompress
    missingok
    notifempty
    create 0644 root root
}

# Nginx access logs (if using nginx)
/var/log/nginx/*.log {
    daily
    rotate 30
    compress
    delaycompress
    missingok
    notifempty
    create 0644 www-data www-data
    sharedscripts
    postrotate
    /bin/kill -USR1 $(cat /var/run/nginx.pid 2>/dev/null || echo "No PID file found") >/dev/null 2>&1 || true
    endscript
}

# Docker logs (if using Docker container logs)
# Docker container logs should be managed by docker log rotation,
# but if you're logging to files:

/var/lib/docker/containers/*/*-json.log {
    daily
    rotate 7
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
    create 0644 root root
}

# Application-specific logs
/var/log/iotdb-enhanced/audit/*.log {
    monthly
    rotate 12
    compress
    delaycompress
    missingok
    notifempty
    create 0640 www-data www-data
}

/var/log/iotdb-enhanced/performance/*.log {
    weekly
    rotate 8
    compress
    delaycompress
    missingok
    notifempty
    create 0640 www-data www-data
}

# System auth logs
/var/log/auth.log {
    monthly
    rotate 4
    missingok
    notifempty
    create 0640 root root
}

# ==============================================================================
# Additional Configuration Options
# ==============================================================================

# Uncomment and modify as needed:

# Maximum size of individual log files before rotation
# maxsize 100M

# Maximum size of all logs before forcing rotation
# maxage 90

# Don't rotate if logs are empty
# notifempty

# Compress logs on rotation
# compress

# Delay compression to next rotation
# delaycompress

# Number of rotations to keep
# rotate 14

# Date extension for rotated logs
# dateext

# Create mode (octal)
# create 0640 www-data www-data

# Don't rotate if log file is missing
# missingok

# Run scripts after rotation
# postrotate
#   /bin/kill -USR1 $(cat /var/run/app.pid 2>/dev/null)
# endscript

# Run scripts before rotation
# prerotate
#   /usr/bin/true
# endscript

# Size-based rotation (uncomment to use size instead of time)
# size 100M

# ==============================================================================
# Testing Log Rotation
# ==============================================================================
#
# To test log rotation without waiting:
#   sudo logrotate -d /etc/logrotate.d/iotdb-enhanced -f -v
#
# To force rotation:
#   sudo logrotate -f /etc/logrotate.d/iotdb-enhanced
#
# To see what logrotate would do without doing it:
#   sudo logrotate -d /etc/logrotate.d/iotdb-enhanced --debug
#
