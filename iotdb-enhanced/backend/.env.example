# ===================================================================
# IoTDB Enhanced Backend - Environment Configuration
# ===================================================================
# Copy this file to .env and update with your actual configuration values
# Generate secure secrets using: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

# -------------------------------------------------------------------------------
# Database Configuration
# -------------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:your_password_here@localhost:5432/iotdb_enhanced"
POSTGRES_URL="postgresql://postgres:your_password_here@localhost:5432/iotdb_enhanced"

# Database Connection Pool
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# -------------------------------------------------------------------------------
# Server Configuration
# -------------------------------------------------------------------------------
PORT=8002
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002

# -------------------------------------------------------------------------------
# Security - JWT Authentication
# -------------------------------------------------------------------------------
# IMPORTANT: Generate a secure secret
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_BASE64_ENCODED_32_BYTE_SECRET
JWT_EXPIRES_IN=7d

# -------------------------------------------------------------------------------
# Security - Session
# -------------------------------------------------------------------------------
# IMPORTANT: Generate a unique secret different from JWT_SECRET
SESSION_SECRET=CHANGE_THIS_TO_A_DIFFERENT_SECURE_BASE64_ENCODED_32_BYTE_SECRET
SESSION_MAX_AGE=604800000

# -------------------------------------------------------------------------------
# Redis Cache Configuration
# -------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Cache TTL (seconds)
CACHE_TTL_DEFAULT=300
CACHE_TTL_SHORT=60
CACHE_TTL_LONG=3600

# -------------------------------------------------------------------------------
# IoTDB Configuration
# -------------------------------------------------------------------------------
# WARNING: Change these default credentials in production!
# The application will log a warning if default credentials are detected.
IOTDB_HOST=localhost
IOTDB_PORT=6667
IOTDB_USERNAME=change_this_username
IOTDB_PASSWORD=change_this_secure_password
IOTDB_DATABASE=root
IOTDB_REST_URL=http://localhost:18080
IOTDB_REST_TIMEOUT=30000

# Connection Pool Configuration
IOTDB_MAX_CONNECTIONS=100
IOTDB_REQUEST_TIMEOUT=60000

# -------------------------------------------------------------------------------
# AI Node Configuration
# -------------------------------------------------------------------------------
AI_NODE_HOME=/opt/iotdb-ainode/apache-iotdb-2.0.5-all-bin
PYTHON_PATH=/opt/iotdb-ainode/apache-iotdb-2.0.5-all-bin/venv/bin/python3
AI_NODE_HOST=localhost
AI_NODE_PORT=10810
AI_NODE_RPC_TIMEOUT=120000

# AI Prediction Timeout
AI_PREDICTION_TIMEOUT=120000

# -------------------------------------------------------------------------------
# Email Configuration (for Alerts)
# -------------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@iotdb-enhanced.com
SMTP_FROM_NAME=IoTDB Enhanced

# -------------------------------------------------------------------------------
# Rate Limiting
# -------------------------------------------------------------------------------
# Rate limit window (milliseconds)
RATE_LIMIT_WINDOW=900000

# Rate limits (requests per window)
RATE_LIMIT_AUTH=5
RATE_LIMIT_API=100
RATE_LIMIT_AI=20
RATE_LIMIT_INGESTION=1000

# -------------------------------------------------------------------------------
# Logging
# -------------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=./logs

# -------------------------------------------------------------------------------
# File Upload
# -------------------------------------------------------------------------------
MAX_FILE_SIZE=10485760
UPLOAD_ALLOWED_TYPES=csv,json

# -------------------------------------------------------------------------------
# Feature Flags
# -------------------------------------------------------------------------------
IOTDB_AI_ENABLED=true
CACHE_ENABLED=true
RATE_LIMIT_ENABLED=true
AUDIT_LOGGING_ENABLED=true

# -------------------------------------------------------------------------------
# Application Settings
# -------------------------------------------------------------------------------
# Maximum prediction horizon
MAX_PREDICTION_HORIZON=1000

# Maximum batch prediction size
MAX_BATCH_PREDICTIONS=10

# Default prediction algorithm
DEFAULT_ALGORITHM=arima

# Session timeout (seconds)
SESSION_TIMEOUT=604800

# -------------------------------------------------------------------------------
# Monitoring (Optional)
# -------------------------------------------------------------------------------
# Prometheus Metrics
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# Sentry Error Tracking
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# -------------------------------------------------------------------------------
# Development Only
# -------------------------------------------------------------------------------
# Enable debug mode (additional logging)
DEBUG=false

# Disable rate limiting in development
DISABLE_RATE_LIMIT=false
