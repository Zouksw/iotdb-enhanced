# ===================================================================
# IoTDB Enhanced Frontend - Environment Configuration
# ===================================================================
# Copy this file to .env.local and update with your actual configuration

# -------------------------------------------------------------------------------
# API Configuration
# -------------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8002
NEXT_PUBLIC_WS_URL=ws://localhost:8002

# -------------------------------------------------------------------------------
# Application Configuration
# -------------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=IoTDB Enhanced
NEXT_PUBLIC_APP_VERSION=1.0.0

# -------------------------------------------------------------------------------
# Feature Flags
# -------------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_MFA=true
NEXT_PUBLIC_ENABLE_API_KEYS=true
NEXT_PUBLIC_ENABLE_ALERTS=true
NEXT_PUBLIC_ENABLE_AI_FEATURES=true

# -------------------------------------------------------------------------------
# UI Configuration
# -------------------------------------------------------------------------------
NEXT_PUBLIC_THEME=light
NEXT_PUBLIC_DEFAULT_LANGUAGE=en
NEXT_PUBLIC_DEFAULT_TIMEZONE=UTC

# -------------------------------------------------------------------------------
# Pagination
# -------------------------------------------------------------------------------
NEXT_PUBLIC_DEFAULT_PAGE_SIZE=20
NEXT_PUBLIC_MAX_PAGE_SIZE=100

# -------------------------------------------------------------------------------
# Chart Configuration
# -------------------------------------------------------------------------------
NEXT_PUBLIC_CHART_MAX_POINTS=1000
NEXT_PUBLIC_CHART_REFRESH_INTERVAL=5000

# -------------------------------------------------------------------------------
# Development Only
# -------------------------------------------------------------------------------
NEXT_PUBLIC_DEBUG=false
