# ==============================================================================
# IoTDB Enhanced - Production Environment Configuration Template
# ==============================================================================
#
# This file contains all the environment variables needed for production deployment.
# Copy this file to `.env.production` and fill in the actual values.
#
# NEVER commit the actual .env.production file to version control!
#
# Setup:
#   1. cp .env.production.template .env.production
#   2. Fill in all the required values
#   3. chmod 600 .env.production (restrict permissions)
#
# ==============================================================================

# ------------------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------------------
NODE_ENV=production
PORT=8000
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# ------------------------------------------------------------------------------
# IMPORTANT: Generate a strong password using:
#   openssl rand -base64 32
# or
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=iotdb_enhanced
DATABASE_USER=postgres
# SECURITY WARNING: Always use a strong, unique password in production
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# For Docker deployments, set POSTGRES_PASSWORD in your .env file
# Example: POSTGRES_PASSWORD=$(openssl rand -base64 32)

# ------------------------------------------------------------------------------
# Redis Configuration (optional, for caching)
# ------------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# ------------------------------------------------------------------------------
# JWT Authentication
# ------------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_GENERATE_STRONG_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# To generate a secure secret, use:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

# ------------------------------------------------------------------------------
# IoTDB Configuration
# ------------------------------------------------------------------------------
# SECURITY WARNING: The default root/root credentials are NOT secure for production!
# You MUST change these before deploying to production.
# Create a new IoTDB user with limited permissions:
#   CREATE USER admin_user WITH PASSWORD 'your_secure_password';
#   GRANT ADMIN ON root TO admin_user;
IOTDB_HOST=localhost
IOTDB_PORT=6667
# CHANGE THIS: Never use root/root in production!
IOTDB_USERNAME=root
IOTDB_PASSWORD=root
IOTDB_FETCH_SIZE=10000
IOTDB_ZONE_ID=Asia/Shanghai

# ------------------------------------------------------------------------------
# AI Node Configuration (for prediction and anomaly detection)
# ------------------------------------------------------------------------------
# AI Node Installation Path
AI_NODE_HOME=/opt/iotdb-ainode/apache-iotdb-2.0.5-all-bin
PYTHON_PATH=/opt/iotdb-ainode/apache-iotdb-2.0.5-all-bin/venv/bin/python3
AI_NODE_HOST=localhost
AI_NODE_PORT=10810
AI_NODE_RPC_TIMEOUT=120000

# Enable/disable AI features (set to true to disable all AI functionality)
AI_FEATURES_DISABLED=false

# AI Isolation Configuration (Process Isolation without Docker)
# Isolation mode: 'process' for prlimit+su isolation, 'docker' for Docker containers
AI_ISOLATION_MODE=process

# Resource limits for isolated AI execution
AI_MAX_MEMORY=512M
AI_MAX_CPU_TIME=60
AI_TIMEOUT=120000

# AI Access Control (Optional IP whitelist - comma separated)
# Leave empty to allow all ADMIN users from any IP
AI_ALLOWED_IPS=

# ------------------------------------------------------------------------------
# CORS Configuration
# ------------------------------------------------------------------------------
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
CORS_CREDENTIALS=true

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ------------------------------------------------------------------------------
# File Upload Configuration
# ------------------------------------------------------------------------------
UPLOAD_MAX_FILE_SIZE=104857600
UPLOAD_ALLOWED_TYPES=.csv,.json
UPLOAD_DIR=/var/uploads

# ------------------------------------------------------------------------------
# Email Configuration (for notifications)
# ------------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=CHANGE_ME_APP_PASSWORD
SMTP_FROM=IoTDB Enhanced <noreply@yourdomain.com>

# ------------------------------------------------------------------------------
# WebSocket Configuration
# ------------------------------------------------------------------------------
WS_ENABLED=true
WS_PATH=/socket.io
WS_CORS_ORIGIN=https://yourdomain.com

# ------------------------------------------------------------------------------
# Encryption
# ------------------------------------------------------------------------------
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_KEY
# To generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"

# ------------------------------------------------------------------------------
# Monitoring & Metrics (Prometheus)
# ------------------------------------------------------------------------------
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
METRICS_PATH=/metrics

# ------------------------------------------------------------------------------
# Logging Configuration
# ------------------------------------------------------------------------------
LOG_DIR=/var/log/iotdb-enhanced
LOG_FILE_MAX_SIZE=20m
LOG_FILE_MAX_FILES=14d

# ------------------------------------------------------------------------------
# Session Configuration
# ------------------------------------------------------------------------------
SESSION_SECRET=CHANGE_ME_ANOTHER_STRONG_SECRET
SESSION_MAX_AGE=86400000
SESSION_SECURE_COOKIES=true
SESSION_COOKIE_NAME=iotdb_session

# ------------------------------------------------------------------------------
# Backup Configuration
# ------------------------------------------------------------------------------
BACKUP_DIR=/var/backups/iotdb-enhanced
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE=0 2 * * *

# S3 Backup (optional)
S3_BUCKET=
S3_PREFIX=iotdb-enhanced/backups
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ------------------------------------------------------------------------------
# Alert Configuration
# ------------------------------------------------------------------------------
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_TO=admin@yourdomain.com
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_METHOD=POST

# ------------------------------------------------------------------------------
# Frontend Configuration
# ------------------------------------------------------------------------------
# These are used by the Next.js frontend
NEXT_PUBLIC_API_URL=https://yourdomain.com/api
NEXT_PUBLIC_WS_URL=wss://yourdomain.com
NEXT_PUBLIC_APP_NAME=IoTDB Enhanced
NEXT_PUBLIC_APP_VERSION=1.0.0

# ------------------------------------------------------------------------------
# SSL/TLS Configuration
# ------------------------------------------------------------------------------
SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
SSL_CA_PATH=/etc/letsencrypt/live/yourdomain.com/chain.pem

# ------------------------------------------------------------------------------
# Security Headers
# ------------------------------------------------------------------------------
HELMET_CSP_DIRECTIVES="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline';"
HELMET_HSTS_MAX_AGE=31536000

# ------------------------------------------------------------------------------
# Cloud Services (optional)
# ------------------------------------------------------------------------------
# AWS
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Azure
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=

# Google Cloud
GCP_PROJECT_ID=
GCP_STORAGE_BUCKET=

# ------------------------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------------------------
FEATURE_AI_FORECASTS=true
FEATURE_ANOMALY_DETECTION=true
FEATURE_REAL_TIME_ALERTS=true
FEATURE_DATA_EXPORT=true
FEATURE_MULTI_TENANT=false

# ------------------------------------------------------------------------------
# Performance Tuning
# ------------------------------------------------------------------------------
CLUSTER_MODE=false
CLUSTER_INSTANCES=max
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# ------------------------------------------------------------------------------
# Developer Tools (DISABLE IN PRODUCTION!)
# ------------------------------------------------------------------------------
DEBUG=false
VERBOSE_LOGGING=false
SWAGGER_ENABLED=false

# ------------------------------------------------------------------------------
# Notification Settings
# ------------------------------------------------------------------------------
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ------------------------------------------------------------------------------
# External Service Integrations
# ------------------------------------------------------------------------------
# Grafana
GRAFANA_URL=http://localhost:3001
GRAFANA_API_KEY=
GRAFANA_DASHBOARD_UID=

# Prometheus Pushgateway
PROMETHEUS_PUSHGATEWAY_URL=http://localhost:9091

# ------------------------------------------------------------------------------
# Docker Configuration (if using containers)
# ------------------------------------------------------------------------------
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_PREFIX=iotdb-enhanced
DOCKER_TAG=latest

# ------------------------------------------------------------------------------
# Git/Deploy Information
# ------------------------------------------------------------------------------
GIT_COMMIT_SHA=
GIT_BRANCH=
DEPLOY_TIMESTAMP=
DEPLOYED_BY=

# ------------------------------------------------------------------------------
# Custom Configuration
# ------------------------------------------------------------------------------
# Add any custom environment variables here
# CUSTOM_VAR=value
